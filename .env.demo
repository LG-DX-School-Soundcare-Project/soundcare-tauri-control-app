# ============================================================
# 시연(데모) 전용 환경설정 — `--mode demo`로 로드된다.
#   npm run dev:demo / build:demo / tauri:dev:demo
# 이 파일은 .env(개인 로컬 설정)보다 우선 적용되므로,
# 데모 모드는 이 전용 스크립트에서만 켜진다. (다른 브랜치/일반 실행 영향 없음)
# ============================================================

# 데모 모드 ON: 백엔드 연결을 모두 끊고 화면을 하드코딩 목 데이터로 채운다.
# (USE_MOCK_API/USE_API_FALLBACK는 DEMO_MODE가 자동으로 켜주지만 명시해 둔다)
VITE_DEMO_MODE=true
VITE_USE_MOCK_API=true
VITE_USE_API_FALLBACK=true

# GPT 상세 리포트는 "유지" 대상 — 실제 백엔드(OpenAI)를 호출한다.
# 이 호출과 인증만 살아있고, 나머지 데이터는 전부 목이다.
VITE_SOUNDCARE_API_BASE_URL=https://soundcare-spring-api-400141016070.asia-northeast3.run.app

# GPT 호출에 필요한 유효 토큰을 받기 위한 자동 로그인용 dev 자격(공유 통합 계정).
VITE_DEV_AUTH_ID_TOKEN=soundcare-integration-shared-2026
VITE_DEV_AUTH_EMAIL=integration.shared@soundcare.local
VITE_DEV_AUTH_DISPLAY_NAME=SoundCare Local Tester

# 데모에서는 로그인 화면을 건너뛰므로 Google 버튼은 쓰지 않는다(비워둠).
VITE_GOOGLE_CLIENT_ID=

# 폴링 간격(데모에서도 무해, 목 데이터라 네트워크 호출은 없음)
VITE_NOTIFICATION_POLL_INTERVAL_MS=15000
VITE_APPLIANCE_MEASUREMENT_POLL_INTERVAL_MS=1000
VITE_DEVICE_AGENT_POLL_INTERVAL_MS=3000
VITE_DEFAULT_ROOM_ID=room-living
VITE_ENABLE_WEBSOCKET_PLACEHOLDER=false
VITE_APPLIANCE_CONTROLLER_DEVICE_ID=aa42b70f-9d83-4de4-969c-2e355b22c689
VITE_APPLIANCE_CONTROLLER_MODULE_ID=esp32s3-appliance-01
VITE_APPLIANCE_CONTROLLER_AGENT_ID=appliance-controller-pc-01
